[flake8]
# Matches the upstream OpenCTI-Platform/connectors lint.yml invocation
# (`flake8 --ignore=E,W .`) - we only want pyflakes errors and mccabe
# complexity warnings, not style checks (black + isort own formatting).
extend-exclude =
    .venv,
    .venv-sdk,
    .git,
    __pycache__,
    .pytest_cache,
    .ruff_cache,
    the local tooling,
    build,
    dist,
    *.egg-info
# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
wheels/

# Virtual environments
.venv/
.venv-sdk/
venv/
env/
.python-version

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Local config (real secrets must never be committed)
config.yml
.env
.env.local
*.local

# Logs
*.log
logs/

# local developer tooling — ignore local settings, but share team agents/skills
.claude/*
!the local tooling/agents/
!the local tooling/skills/

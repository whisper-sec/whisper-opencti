OPENCTI_ADMIN_TOKEN=0d9e7c3b-5d2a-4c8f-9e1b-3a7f6b9c5e2d

MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=opencti-dev-only

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

ELASTIC_MEMORY_SIZE=2G

CONNECTOR_ID=7a4f2c8e-9b1d-4f6a-8c3e-2b5a7d9f1c4e

WHISPER_API_URL=https://graph.whisper.security
WHISPER_API_KEY=dev-placeholder-key

# Copy to `.env` (gitignored) and fill in values.
#
# Two audiences for this file:
#
#   Developer / QA running the local stack
#     - `.env.dev` (committed) already provides working values for every
#       variable below.
#     - Set WHISPER_API_KEY only - leave the rest commented so the
#       `.env.dev` defaults apply.
#     - The Makefile layers `.env` on top of `.env.dev`, so anything you
#       set wins over the default.
#
#   Production admin deploying the connector
#     - There is no `.env.dev` in production - set every non-comment line
#       below.
#     - Do NOT reuse any value from `.env.dev`. The committed dev OpenCTI
#       admin token, MinIO password, RabbitMQ guest/guest, etc. are
#       local-only and not safe to expose.

# === Required for any real enrichment ===
# Without this, the connector starts and registers with OpenCTI but
# every enrichment call returns WhisperAuthError.
WHISPER_API_KEY=

# === OpenCTI platform ===
# Production: set all of these. Local dev: leave commented - defaults
# from .env.dev apply.
# OPENCTI_VERSION=6.4.5
# OPENCTI_PORT=8080
# OPENCTI_BASE_URL=http://localhost:8080
# OPENCTI_ADMIN_EMAIL=
# OPENCTI_ADMIN_PASSWORD=
# OPENCTI_ADMIN_TOKEN=

# === Object storage (MinIO) ===
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=

# === Message queue (RabbitMQ) ===
# Production: replace guest/guest with strong credentials.
# RABBITMQ_DEFAULT_USER=
# RABBITMQ_DEFAULT_PASS=

# === Elasticsearch ===
# ELASTIC_MEMORY_SIZE=2G

# === Connector ===
# Generate one UUIDv4 per instance (e.g. `uuidgen`) and keep it stable
# across restarts - rotating it makes OpenCTI think it's a new connector.
# CONNECTOR_ID=

# === Whisper API ===
# WHISPER_API_URL=https://graph.whisper.security
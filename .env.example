# Local Compose stack environment - single source of truth.
#
# Setup on a fresh clone:
#   1. cp .env.example .env       (.env is gitignored)
#   2. Edit .env: set WHISPER_API_KEY to a real Whisper Security key.
#   3. make dev-up                (or make qa-up)
#
# The Makefile loads only `.env`. There is no fallback - if `.env` is
# missing, `make dev-up` / `make qa-up` exit with a clear hint to run
# `cp .env.example .env` first.
#
# The values below are working dev defaults - safe to commit because
# they only have meaning inside the local Compose network (MinIO and
# RabbitMQ aren't exposed on the host; the OpenCTI token is internal).
# For production deployments, replace every value with a real one.

# === Required for real enrichment ===
# Get a key from Whisper Security. The placeholder below lets the
# connector start and register with OpenCTI, but every enrichment
# call returns WhisperAuthError until a real key is set.
WHISPER_API_KEY=dev-placeholder-key

# === OpenCTI platform ===
# Production: replace every value here with real credentials.
OPENCTI_VERSION=7.260701.0
OPENCTI_PORT=8080
OPENCTI_BASE_URL=http://localhost:8080
OPENCTI_ADMIN_EMAIL=admin@whisper.local
OPENCTI_ADMIN_PASSWORD=ChangeMe-dev-only
OPENCTI_ADMIN_TOKEN=0d9e7c3b-5d2a-4c8f-9e1b-3a7f6b9c5e2d
# OpenCTI v7 requires a 32-byte base64 encryption key. Generate a fresh
# one for production with `openssl rand -base64 32`. The committed value
# is a deterministic placeholder for the local dev / qa stacks only -
# never re-use it in production.
OPENCTI_ENCRYPTION_KEY=SxNbNBiQNyl+pSGo/PV6U97T3QuYDfgYvoU/GpXmy/s=

# === Object storage (MinIO) ===
MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=opencti-dev-only

# === Message queue (RabbitMQ) ===
# Production: replace guest/guest with strong credentials.
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# === Elasticsearch ===
ELASTIC_MEMORY_SIZE=2G

# === Connector ===
# Generate a fresh UUIDv4 per production instance (`uuidgen`) and keep
# it stable across restarts. The dev default below is fine for local use.
CONNECTOR_ID=7a4f2c8e-9b1d-4f6a-8c3e-2b5a7d9f1c4e

# Connector image version pulled by the QA stack (`make qa-up`). Override
# this in your local `.env` to validate a release candidate, e.g.
# WHISPER_CONNECTOR_VERSION=v0.2.0-rc1
WHISPER_CONNECTOR_VERSION=v0.1.0

# === Whisper API ===
WHISPER_API_URL=https://graph.whisper.security

# === Agent-activity log source (OPTIONAL, EXTERNAL_IMPORT sibling) ===
# Only needed if you also run the log-source connector
# (docker-compose.logs.yml). It reuses WHISPER_API_URL / WHISPER_API_KEY above
# - no second credential. Generate a FRESH uuid, distinct from CONNECTOR_ID.
CONNECTOR_LOGS_ID=8f3b1d92-6c47-4a0e-b5d1-2e9c7a4f0b63
CONNECTOR_LOGS_DURATION_PERIOD=PT5M
# How far back the first run reads (relative window / epoch-ms / RFC3339).
WHISPER_LOGS_INITIAL_LOOKBACK=-24h